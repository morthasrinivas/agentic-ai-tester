# ── Copy this file to .env and fill in your values ──────────────────────────

# OpenAI API key (required if EMBEDDING_PROVIDER=openai or for GPT models)
OPENAI_API_KEY=sk-...

# LLM model to use. Options: gpt-4o, gpt-4o-mini, gpt-3.5-turbo
LLM_MODEL=gpt-4o-mini

# Temperature for LLM responses (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.1

# Embedding provider: "local" (no API key, uses sentence-transformers)
#                  or "openai" (uses text-embedding-3-small, needs API key)
EMBEDDING_PROVIDER=local

# Max Agent B → Agent C loop iterations (default: 5)
MAX_ITERATIONS=5
